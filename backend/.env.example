PORT=3001
JWT_SECRET=cambiar-en-produccion

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sem?schema=public"

# Cuenta Municipalidad (creada con npm run seed)
MUNICIPIO_EMAIL=municipio@salta.gob.ar
MUNICIPIO_PASSWORD=

# Dev tools: panel de cambio de cuenta en el frontend + cuentas demo en seed
ENABLE_DEV_TOOLS=false

# URLs públicas (localto.net, producción, etc.)
# Frontend: sem.localto.net — API: apisem.localto.net
FRONTEND_URL=https://sem.localto.net
API_PUBLIC_URL=https://apisem.localto.net
# Orígenes CORS separados por coma (se suman a FRONTEND_URL y localhost)
CORS_ORIGINS=http://localhost:5173,https://sem.localto.net
# En dev (ENABLE_DEV_TOOLS=true o NODE_ENV!=production) también se permiten
# localhost, *.localto.net y cualquier origen. En producción solo los de arriba + localto.

# Mercado Pago OAuth (redirect_uri debe coincidir con la app de MP)
MP_CLIENT_ID=2988781161305187
# Client Secret de la aplicación (NO es un Access Token APP_USR-)
MP_CLIENT_SECRET=
MP_REDIRECT_URI=https://apisem.localto.net/oauth/callback
MP_PUBLIC_KEY=
MP_NOTIFICATION_URL=https://apisem.localto.net/api/payments/webhook

# Opcional: JSON con cuentas dev personalizadas para npm run seed
# DEV_SEED_ACCOUNTS=[{"email":"admin@ejemplo.com","password":"tu-clave","name":"Admin","role":"admin"}]
