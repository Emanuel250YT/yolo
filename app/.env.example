# URL base de la API (relativa con proxy local, absoluta con localto.net)
# Local con proxy Vite:  VITE_API_URL=/api
# Túnel localto.net:     VITE_API_URL=https://apisem.localto.net/api
VITE_API_URL=/api

# URL pública del frontend (opcional, para referencia)
# VITE_APP_URL=https://sem.localto.net

# Herramientas de desarrollo (requiere también ENABLE_DEV_TOOLS=true en backend)
VITE_DEV_TOOLS=true

# Cuentas rápidas para cambiar de rol (JSON array)
# VITE_DEV_ACCOUNTS=[{"label":"Municipio","email":"municipio@ejemplo.com","password":"tu-clave"},{"label":"Admin","email":"admin@ejemplo.com","password":"tu-clave"},{"label":"Permisionario","email":"perm@ejemplo.com","password":"tu-clave"},{"label":"Conductor","email":"conductor@ejemplo.com","password":"tu-clave"}]
